# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cradera

# Redis (Optional but recommended for sessions)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# CORS and Links (Frontend URL)
FRONTEND_URL=https://cradera-dashboard.vercel.app
# CLIENT_URL (Legacy fallback, use FRONTEND_URL instead)
CLIENT_URL=https://cradera-dashboard.vercel.app

# Email Service (Resend)
RESEND_API_KEY=re_123456789
LOGO_URL=https://cradera-dashboard.vercel.app/logo.png
