{
  "info": {
    "name": "Cradera Express API",
    "description": "Refactored Express.js REST API for the Cradera platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "http://localhost:4000/api/v1/auth/register", "protocol": "http", "host": [ "localhost" ], "port": "4000", "path": [ "api", "v1", "auth", "register" ] },
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"test@cradera.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "http://localhost:4000/api/v1/auth/login", "protocol": "http", "host": [ "localhost" ], "port": "4000", "path": [ "api", "v1", "auth", "login" ] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@cradera.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "http://localhost:4000/api/v1/auth/me", "protocol": "http", "host": [ "localhost" ], "port": "4000", "path": [ "api", "v1", "auth", "me" ] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "http://localhost:4000/api/v1/users/profile", "protocol": "http", "host": [ "localhost" ], "port": "4000", "path": [ "api", "v1", "users", "profile" ] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Logs",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
            "url": { "raw": "http://localhost:4000/api/v1/admin/logs", "protocol": "http", "host": [ "localhost" ], "port": "4000", "path": [ "api", "v1", "admin", "logs" ] }
          }
        }
      ]
    }
  ]
}
